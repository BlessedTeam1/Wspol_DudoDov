<Window x:Class="PresentationView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculator" Height="280" Width="360"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- First number -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="First number:" Width="110" VerticalAlignment="Center"/>
            <TextBox x:Name="TxtFirstNumber" Width="150" Text="0"/>
        </StackPanel>

        <!-- Operation -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Operation:" Width="110" VerticalAlignment="Center"/>
            <ComboBox x:Name="CmbOperation" Width="150" SelectedIndex="0">
                <ComboBoxItem Content="+"/>
                <ComboBoxItem Content="-"/>
                <ComboBoxItem Content="*"/>
                <ComboBoxItem Content="/"/>
            </ComboBox>
        </StackPanel>

        <!-- Second number -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Second number:" Width="110" VerticalAlignment="Center"/>
            <TextBox x:Name="TxtSecondNumber" Width="150" Text="0"/>
        </StackPanel>

        <!-- Calculate button -->
        <Button Grid.Row="3" Content="Calculate" Width="100"
                HorizontalAlignment="Left" Margin="110,10,0,0"
                Click="BtnCalculate_Click"/>

        <!-- Result -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10">
            <TextBlock Text="Result:" Width="110" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBlock x:Name="TxtResult" Width="200" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
